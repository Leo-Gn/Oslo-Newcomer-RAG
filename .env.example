# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Security limits
REQUEST_BODY_LIMIT_BYTES=131072
RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_PER_MINUTE=20
FEEDBACK_RATE_LIMIT_PER_MINUTE=60

# Database
POSTGRES_USER=oslo_newcomer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=oslo_newcomer
DATABASE_URL=postgresql+psycopg://oslo_newcomer:change-me@localhost:5432/oslo_newcomer

# OpenAI-compatible model provider
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-api-key
LLM_MODEL=replace-with-chat-model
EMBEDDING_MODEL=replace-with-embedding-model
EMBEDDING_DIM=1536
